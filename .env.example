# ─── LLM ────────────────────────────────────────────────────────────────────
# Gemini Vision — free tier: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_VISION_MODEL=gemini-1.5-flash

# Ollama — runs locally (https://ollama.ai)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_CHAT_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text

# ─── DATABASE (PostgreSQL) ───────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=pid_intelligence
POSTGRES_USER=pid_user
POSTGRES_PASSWORD=change_me_in_production
DATABASE_URL=postgresql+asyncpg://pid_user:change_me_in_production@postgres:5432/pid_intelligence

# ─── VECTOR DB (ChromaDB) ───────────────────────────────────────────────────
CHROMA_PERSIST_DIR=/app/chroma_db

# ─── STORAGE ────────────────────────────────────────────────────────────────
UPLOAD_DIR=/app/data/pids
MANUALS_DIR=/app/data/manuals
GRAPH_DIR=/app/data/graphs
MAX_UPLOAD_SIZE_MB=50

# ─── API ────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
# Comma-separated list of frontend origins allowed to call the API.
# Add your server's LAN IP when enabling network access.
# Example: CORS_ORIGINS=http://localhost:5173,http://192.168.1.100:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32

# ─── GITHUB (for in-app bug reporting) ──────────────────────────────────────
GITHUB_TOKEN=your_github_pat_here
GITHUB_REPO=your_username/pid-intelligence-system

# ─── ENVIRONMENT ────────────────────────────────────────────────────────────
# Options: development | staging | production | test
APP_ENV=development
LOG_LEVEL=INFO

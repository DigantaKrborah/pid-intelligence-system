# Copy this file to .env and fill in your values
# Never commit the .env file to git

# --- Database ---
DATABASE_URL=postgresql://postgres:[YOUR_PASSWORD]@localhost:5432/pid_system

# --- File Storage (local only) ---
UPLOAD_BASE_PATH=E:/PID_Reader/uploads

# --- Authentication ---
JWT_SECRET=
JWT_EXPIRE_HOURS=8

# --- AI Provider (claude / openai / gemini) ---
DEFAULT_LLM_PROVIDER=claude

# --- PDF Processing ---
POPPLER_PATH=C:/poppler/Library/bin

# --- CORS (allowed frontend origins) ---
# Always includes localhost. Add your server's LAN IP for network access.
# Example: CORS_ORIGINS=http://localhost:5173,http://192.168.1.100:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
